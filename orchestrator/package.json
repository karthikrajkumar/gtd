{
  "name": "@gtd/sandbox-service",
  "version": "0.1.0",
  "description": "GTD Sandbox Service — creates isolated Docker workspaces with GTD MCP tools exposed over HTTP. Plug into any orchestrator.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/cors": "^11.0.1",
    "dockerode": "^4.0.7",
    "uuid": "^11.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.20"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "@types/node": "^22.15.18",
    "@types/dockerode": "^3.3.38",
    "@types/uuid": "^10.0.0",
    "vitest": "^3.1.0"
  }
}
