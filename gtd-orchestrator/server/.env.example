# ─── Required ────────────────────────────────────────────────────
# Your Google AI (Gemini) API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Optional — defaults shown ───────────────────────────────────
# Server port
PORT=4000

# Sandbox service URL (the orchestrator/ service)
SANDBOX_SERVICE_URL=http://localhost:3000

# Gemini model (gemini-2.5-flash, gemini-2.5-pro, etc.)
GEMINI_MODEL=gemini-2.5-flash

# Max output tokens per Gemini response
GEMINI_MAX_TOKENS=8192

# Timeout for MCP tool calls in ms (must be > GTD's 60s execSync)
MCP_TOOL_TIMEOUT_MS=70000

# Log level
NODE_ENV=development
